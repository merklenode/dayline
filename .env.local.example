# LocusGraph server URL. Defaults to https://us-east-1.locusgraph.com.
LOCUSGRAPH_SERVER_URL=https://us-east-1.locusgraph.com

# Required: agent secret from the LocusGraph Tokens page.
LOCUSGRAPH_AGENT_SECRET=

# Required: graph ID to scope Dayline memories.
LOCUSGRAPH_GRAPH_ID=

# Optional Anthropic key used by the Oracle insight route.
ANTHROPIC_API_KEY=

# Set to "true" to enable LocusGraph sync and Oracle insights in the browser UI.
# This is read at build time by Next.js, so changing it requires a rebuild.
NEXT_PUBLIC_LOCUSGRAPH_ENABLED=
