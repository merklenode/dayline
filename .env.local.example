# LocusGraph server URL (optional — defaults to https://us-east-1.locusgraph.com)
LOCUSGRAPH_SERVER_URL=

# Required: agent secret used to authenticate with LocusGraph.
# The build will fail if this is unset — add a placeholder value when building locally
# without a real LocusGraph account.
LOCUSGRAPH_AGENT_SECRET=

# Optional: graph ID to scope all LocusGraph operations.
# If omitted, graph_id must be included in each API request body.
LOCUSGRAPH_GRAPH_ID=

# Set to "true" to enable LocusGraph integration in the browser UI (future use).
NEXT_PUBLIC_LOCUSGRAPH_ENABLED=
